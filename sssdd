task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local target = (human and human.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    if not target then return end

    -- === ТВОИ ТОЧНЫЕ КООРДИНАТЫ ГАРАЖА ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 -- Высота полета (в сумме будет около 160)

    -- Чистим невидимые стены
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка "двигателей"
    local att0 = Instance.new("Attachment", target)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    att1.CFrame = target.CFrame 

    local ap = Instance.new("AlignPosition", target)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", target)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200; ao.RigidityEnabled = true

    local function move(targetCF, duration, style)
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === МАРШРУТ ПОБЕГА ===

    print("Шаг 1: 100м прямо")
    move(att1.CFrame * CFrame.new(0, 0, -100), 4, Enum.EasingStyle.Quad)

    print("Шаг 2: Взлет на 70м")
    move(att1.CFrame * CFrame.new(0, flyHeight, 0), 3, Enum.EasingStyle.Quad)

    print("Шаг 3: Поворот корпуса НАЛЕВО")
    move(att1.CFrame * CFrame.Angles(0, math.rad(90), 0), 2)

    print("Шаг 4: Наведение НОСА на Гараж")
    -- Плавно разворачиваем машину лицом к твоим координатам
    local lookAtTarget = CFrame.new(att1.Position, Vector3.new(garagePos.X, att1.Position.Y, garagePos.Z))
    move(lookAtTarget, 2.5, Enum.EasingStyle.Quad)

    print("Шаг 5: ПРЯМОЙ ПЕРЕЛЕТ")
    -- Летим ровно в ту точку, которую ты скинул
    local finalFly = CFrame.new(garagePos + Vector3.new(0, flyHeight, 0), garagePos)
    move(finalFly, 12, Enum.EasingStyle.Linear)

    print("Шаг 6: Посадка")
    move(CFrame.new(garagePos), 3, Enum.EasingStyle.Quad)

    -- Удаляем силы, возвращаем физику
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Миссия выполнена! Мы в гараже.")
end)
