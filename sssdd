task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    
    -- Определяем, что двигать: машину (если сидим) или самого игрока
    local root = char:FindFirstChild("HumanoidRootPart")
    local human = char:FindFirstChildOfClass("Humanoid")
    local targetToMove = root

    if human and human.SeatPart then
        targetToMove = human.SeatPart -- Если в машине, двигаем сиденье
    end

    if not targetToMove then return end

    -- Координаты Гаража (Склад)
    local garagePos = Vector3.new(-920, 70, -1500) 
    local flyHeight = 70

    -- Чистим невидимые стены в небе
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка "двигателей" (физика без гравитации)
    local att0 = Instance.new("Attachment", targetToMove)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    att1.WorldCFrame = targetToMove.WorldCFrame

    local ap = Instance.new("AlignPosition", targetToMove)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", targetToMove)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200; ao.RigidityEnabled = true

    -- Функция плавного хода
    local function move(targetCF, duration, style)
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {WorldCFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === ТВОЙ МАРШРУТ ===

    print("Старт: 100 метров прямо...")
    move(targetToMove.WorldCFrame * CFrame.new(0, 0, -100), 4, Enum.EasingStyle.Quad)

    print("Взлет: на 70 метров...")
    move(att1.WorldCFrame * CFrame.new(0, flyHeight, 0), 3, Enum.EasingStyle.Quad)

    print("Маневр: Поворот НАЛЕВО...")
    -- Поворачиваемся на 90 градусов влево
    move(att1.WorldCFrame * CFrame.Angles(0, math.rad(90), 0), 2, Enum.EasingStyle.Quad)

    print("Перелет: Курс на Гараж!")
    local finalLook = CFrame.new(garagePos, garagePos + (garagePos - att1.WorldPosition).Unit)
    move(finalLook, 15, Enum.EasingStyle.Linear)

    print("Финиш: Мягкая посадка...")
    move(att1.WorldCFrame * CFrame.new(0, -flyHeight, 0), 3, Enum.EasingStyle.Quad)

    -- Удаляем силы
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Прибыли в гараж!")
end)
