task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    local seat = char and char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").SeatPart
    
    if not (seat and seat:IsA("VehicleSeat")) then return end
    local car = seat.Parent

    -- Настройки
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. Создаем "двигатели" (Velocity не ломает колеса)
    local bv = Instance.new("BodyVelocity", seat)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)

    local bg = Instance.new("BodyGyro", seat)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.CFrame = seat.CFrame

    -- Функция для плавного полета через изменение скорости
    local function fly(targetPos, speed)
        local distance = (targetPos - seat.Position).Magnitude
        local duration = distance / speed
        
        -- Поворачиваем нос строго горизонтально к цели
        local lookTarget = Vector3.new(targetPos.X, seat.Position.Y, targetPos.Z)
        bg.CFrame = CFrame.lookAt(seat.Position, lookTarget)
        
        -- Задаем скорость движения
        bv.Velocity = (targetPos - seat.Position).Unit * speed
        task.wait(duration)
        bv.Velocity = Vector3.new(0, 0, 0)
    end

    -- === МАРШРУТ (КОЛЕСА БУДУТ НА МЕСТЕ) ===

    print("1. Разгон 100м")
    fly((seat.CFrame * CFrame.new(0, 0, -100)).Position, 30)

    print("2. Взлет вверх")
    fly(seat.Position + Vector3.new(0, flyHeight, 0), 25)

    print("3. Поворот НАЛЕВО")
    bg.CFrame = bg.CFrame * CFrame.Angles(0, math.rad(90), 0)
    task.wait(1.5)

    print("4. Наведение на Гараж")
    local garageAtHeight = Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z)
    bg.CFrame = CFrame.lookAt(seat.Position, garageAtHeight)
    task.wait(1.5)

    print("5. Перелет")
    fly(garageAtHeight, 50) -- Летим быстрее

    print("6. Посадка")
    fly(garagePos, 20)

    -- Финал: Удаляем силы плавно
    task.wait(0.5)
    bv:Destroy()
    bg:Destroy()
    print("Приехали! Все детали на месте.")
end)
