task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local RunService = game:GetService("RunService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    if not seat then print("Сядь в машину!") return end

    local car = seat.Parent
    while car and not car:IsA("Model") do car = car.Parent end

    -- === НАСТРОЙКИ (ТВОИ КООРДИНАТЫ) ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. ПОДГОТОВКА: Запоминаем положение каждой детали относительно сиденья
    local carParts = {}
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            -- Запоминаем смещение (Offset) относительно сиденья
            carParts[p] = seat.CFrame:Inverse() * p.CFrame
            p.Anchored = true
            p.CanCollide = false -- Чтобы не цеплялись за землю в полете
        end
    end

    -- 2. ГЛАВНЫЙ ЦИКЛ: Принудительно держим детали на месте каждый кадр
    local locking = true
    local connection = RunService.Heartbeat:Connect(function()
        if not locking then return end
        for part, offset in pairs(carParts) do
            if part and part.Parent then
                part.CFrame = seat.CFrame * offset
            end
        end
    end)

    -- Удаляем невидимые стены в небе
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Функция для перемещения
    local function move(targetCF, duration, style)
        local tween = TweenService:Create(seat, TweenInfo.new(duration, style or Enum.EasingStyle.Linear), {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === МАРШРУТ (БЕЗ ШАНСОВ ДЛЯ ГЛЮКОВ) ===

    print("1. Разгон 100м")
    move(seat.CFrame * CFrame.new(0, 0, -100), 4, Enum.EasingStyle.Quad)

    print("2. Взлет на 70м")
    local upPos = seat.Position + Vector3.new(0, flyHeight, 0)
    move(CFrame.new(upPos) * (seat.CFrame - seat.Position), 3, Enum.EasingStyle.Quad)

    print("3. Поворот НАЛЕВО")
    move(seat.CFrame * CFrame.Angles(0, math.rad(90), 0), 2)

    print("4. Наведение на Гараж")
    local lookCF = CFrame.lookAt(seat.Position, Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z))
    move(lookCF, 2)

    print("5. Перелет")
    local flyTo = CFrame.new(garagePos + Vector3.new(0, flyHeight, 0), garagePos)
    move(flyTo, 12)

    print("6. Посадка")
    move(CFrame.new(garagePos) * (lookCF - lookCF.Position), 3, Enum.EasingStyle.Quad)

    -- ФИНАЛ: Возвращаем всё как было
    print("Прибыли! Возвращаем физику...")
    locking = false
    connection:Disconnect()
    task.wait(0.5)
    
    for part, _ in pairs(carParts) do
        if part and part.Parent then
            part.Anchored = false
            part.CanCollide = true
        end
    end
    print("Миссия завершена. Все детали на месте!")
end)
