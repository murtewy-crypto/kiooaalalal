task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local target = (human and human.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    if not target then return end

    -- === ТВОИ ТОЧНЫЕ КООРДИНАТЫ ГАРАЖА ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 -- Высота взлета

    -- Очистка невидимых стен
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка "двигателей"
    local att0 = Instance.new("Attachment", target)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    att1.CFrame = target.CFrame 

    local ap = Instance.new("AlignPosition", target)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", target)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200; ao.RigidityEnabled = true

    -- Функция для перемещения БЕЗ возможности наклона (только горизонтальный поворот)
    local function moveSafe(targetPos, duration, style)
        -- Создаем точку взгляда на той же высоте, что и машина (чтобы не было наклона вверх/вниз)
        local lookAtTarget = Vector3.new(targetPos.X, att1.Position.Y, targetPos.Z)
        
        -- Если мы стоим на месте (взлет вверх), сохраняем текущий поворот
        local targetCF
        if (lookAtTarget - att1.Position).Magnitude < 0.1 then
            targetCF = CFrame.new(targetPos) * (att1.CFrame - att1.Position)
        else
            targetCF = CFrame.lookAt(targetPos, lookAtTarget)
        end
        
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === ТВОЙ ИДЕАЛЬНЫЙ МАРШРУТ (БЕЗ НАКЛОНОВ) ===

    print("1. Едем прямо 100 метров...")
    local p1 = (att1.CFrame * CFrame.new(0, 0, -100)).Position
    moveSafe(p1, 4, Enum.EasingStyle.Quad)

    print("2. Взлетаем вверх на 70 метров...")
    local p2 = p1 + Vector3.new(0, flyHeight, 0)
    moveSafe(p2, 3, Enum.EasingStyle.Quad)

    print("3. Поворот НАЛЕВО на 90 градусов...")
    -- Поворачиваем строго по горизонтали
    local leftCF = CFrame.new(att1.Position) * (att1.CFrame - att1.Position) * CFrame.Angles(0, math.rad(90), 0)
    TweenService:Create(att1, TweenInfo.new(2, Enum.EasingStyle.Quad), {CFrame = leftCF}):Play()
    task.wait(2.1)

    print("4. Разворот носа на Гараж (горизонтально)...")
    -- Направляем нос на гараж, но точку взгляда ставим на своей высоте
    local garageAtMyHeight = Vector3.new(garagePos.X, att1.Position.Y, garagePos.Z)
    local lookAtGarageCF = CFrame.lookAt(att1.Position, garageAtMyHeight)
    TweenService:Create(att1, TweenInfo.new(2, Enum.EasingStyle.Quad), {CFrame = lookAtGarageCF}):Play()
    task.wait(2.1)

    print("5. Летим к Гаражу...")
    -- Летим в точку НАД гаражом на текущей высоте полета
    local p3 = Vector3.new(garagePos.X, att1.Position.Y, garagePos.Z)
    moveSafe(p3, 12, Enum.EasingStyle.Linear)

    print("6. Мягкая посадка...")
    -- Просто опускаемся вниз, сохраняя поворот
    moveSafe(garagePos, 3, Enum.EasingStyle.Quad)

    -- Удаляем силы
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Миссия выполнена: Ровно и четко!")
end)
