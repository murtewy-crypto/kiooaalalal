task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local target = (human and human.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    if not target then return end

    -- === ТВОИ ТОЧНЫЕ КООРДИНАТЫ ГАРАЖА ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- Очистка стен
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка сил
    local att0 = Instance.new("Attachment", target)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    att1.CFrame = target.CFrame 

    local ap = Instance.new("AlignPosition", target)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", target)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200
    ao.RigidityEnabled = true -- Жесткая фиксация

    -- Функция для полета БЕЗ наклонов (горизонтально)
    local function moveStraight(targetPos, duration, style)
        -- ВАЖНО: Мы зануляем разницу по высоте для поворота, чтобы машина не задирала нос
        local lookPos = Vector3.new(targetPos.X, att1.Position.Y, targetPos.Z)
        local targetCF = CFrame.new(targetPos, lookPos)
        
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === МАРШРУТ (БЕЗ ВЕРТИКАЛЬНЫХ ТРЮКОВ) ===

    print("Шаг 1: 100м прямо по земле")
    local p1 = (att1.CFrame * CFrame.new(0, 0, -100)).Position
    moveStraight(p1, 4, Enum.EasingStyle.Quad)

    print("Шаг 2: Вертикальный взлет (сохраняем горизонт)")
    local p2 = p1 + Vector3.new(0, flyHeight, 0)
    -- При взлете смотрим туда же, куда смотрели
    local liftCF = CFrame.new(p2, p2 + att1.CFrame.LookVector)
    TweenService:Create(att1, TweenInfo.new(3, Enum.EasingStyle.Quad), {CFrame = liftCF}):Play()
    task.wait(3.1)

    print("Шаг 3: Разворот носа на Гараж")
    local lookAtGarage = CFrame.new(att1.Position, Vector3.new(garagePos.X, att1.Position.Y, garagePos.Z))
    TweenService:Create(att1, TweenInfo.new(2, Enum.EasingStyle.Quad), {CFrame = lookAtGarage}):Play()
    task.wait(2.1)

    print("Шаг 4: Перелет носом вперед")
    local p3 = Vector3.new(garagePos.X, att1.Position.Y, garagePos.Z)
    moveStraight(p3, 12, Enum.EasingStyle.Linear)

    print("Шаг 5: Посадка")
    moveStraight(garagePos, 3, Enum.EasingStyle.Quad)

    -- Удаляем силы
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Приземлились ровно!")
end)
