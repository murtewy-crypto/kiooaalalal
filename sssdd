task.spawn(function()
    local player = game.Players.LocalPlayer
    local char = player.Character
    local human = char and char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    
    -- Проверка: сидим ли мы в машине
    if not (seat and seat:IsA("VehicleSeat")) then 
        print("ОШИБКА: Сначала сядь в машину!")
        return 
    end

    -- Твои координаты гаража
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. Удаляем старые силы, чтобы не мешались
    for _, child in pairs(seat:GetChildren()) do
        if child:IsA("BodyVelocity") or child:IsA("BodyGyro") then
            child:Destroy()
        end
    end

    -- 2. Создаем новые силы (используем только .CFrame)
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = seat

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.D = 500
    bg.CFrame = seat.CFrame -- Используем просто .CFrame!
    bg.Parent = seat

    -- === ТВОЙ МАРШРУТ ===

    -- ФАЗА 1: 100 метров прямо
    print("Этап 1: Прямо")
    bv.Velocity = seat.CFrame.LookVector * 25
    task.wait(4) 

    -- ФАЗА 2: Взлет вверх на 70 метров
    print("Этап 2: Вверх")
    bv.Velocity = Vector3.new(0, 25, 0)
    task.wait(flyHeight / 25)
    bv.Velocity = Vector3.new(0, 0, 0)

    -- ФАЗА 3: Поворот НАЛЕВО
    print("Этап 3: Налево")
    bg.CFrame = bg.CFrame * CFrame.Angles(0, math.rad(90), 0)
    task.wait(2)

    -- ФАЗА 4: Полет к Гаражу (Горизонтально!)
    print("Этап 4: К гаражу")
    -- Вычисляем направление, игнорируя высоту (Y = 0), чтобы нос не задирался
    local currentPos = seat.Position
    local targetOnHeight = Vector3.new(garagePos.X, currentPos.Y, garagePos.Z)
    local direction = (targetOnHeight - currentPos).Unit
    
    -- Поворачиваем нос на цель
    bg.CFrame = CFrame.lookAt(currentPos, currentPos + direction)
    task.wait(1.5)
    
    -- Летим
    bv.Velocity = direction * 55
    while (Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z) - seat.Position).Magnitude > 10 do
        task.wait()
    end
    bv.Velocity = Vector3.new(0, 0, 0)

    -- ФАЗА 5: Приземление
    print("Этап 5: Посадка")
    bv.Velocity = Vector3.new(0, -20, 0)
    while (seat.Position.Y - garagePos.Y) > 3 do
        task.wait()
    end

    -- ФИНАЛ
    bv.Velocity = Vector3.new(0, 0, 0)
    task.wait(1)
    bv:Destroy()
    bg:Destroy()
    print("Приземление окончено!")
end)
