task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local target = (human and human.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    if not target then return end

    -- === ТВОИ ТОЧНЫЕ КООРДИНАТЫ ГАРАЖА ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 -- Высота над землей

    -- Очистка невидимых стен в небе
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка "двигателей"
    local att0 = Instance.new("Attachment", target)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    att1.CFrame = target.CFrame 

    local ap = Instance.new("AlignPosition", target)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", target)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200
    ao.RigidityEnabled = true -- Жестко держим корпус, чтобы не качался

    -- Функция для перемещения СТРОГО горизонтально
    local function move(targetPos, duration, style)
        -- Вычисляем направление взгляда, игнорируя высоту (Y), чтобы нос не задирался
        local currentPos = att1.Position
        local direction = (targetPos - currentPos).Unit
        local flatDirection = Vector3.new(direction.X, 0, direction.Z).Unit
        
        local targetCF = CFrame.new(targetPos, targetPos + flatDirection)
        
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === МАРШРУТ (БЕЗ ПЕРЕКОСОВ) ===

    print("1. Едем прямо (100м)")
    local p1 = (att1.CFrame * CFrame.new(0, 0, -100)).Position
    move(p1, 4, Enum.EasingStyle.Quad)

    print("2. Взлет (70м вверх)")
    -- При взлете просто меняем Y, но LookVector оставляем тот же
    local p2 = p1 + Vector3.new(0, flyHeight, 0)
    local liftCF = CFrame.new(p2, p2 + att1.CFrame.LookVector)
    TweenService:Create(att1, TweenInfo.new(3, Enum.EasingStyle.Quad), {CFrame = liftCF}):Play()
    task.wait(3.1)

    print("3. Поворот НАЛЕВО (на месте)")
    -- Поворачиваем строго по оси Y
    local leftCF = att1.CFrame * CFrame.Angles(0, math.rad(90), 0)
    TweenService:Create(att1, TweenInfo.new(2, Enum.EasingStyle.Quad), {CFrame = leftCF}):Play()
    task.wait(2.1)

    print("4. Разворот на Гараж и ПРЯМОЙ перелет")
    -- Находим направление на гараж, но "прижимаем" его к горизонту
    local p3 = garagePos + Vector3.new(0, flyHeight, 0)
    local directionToGarage = (p3 - att1.Position).Unit
    local flatDir = Vector3.new(directionToGarage.X, 0, directionToGarage.Z).Unit
    
    -- Сначала плавно поворачиваем нос
    local lookAtCF = CFrame.new(att1.Position, att1.Position + flatDir)
    TweenService:Create(att1, TweenInfo.new(2, Enum.EasingStyle.Quad), {CFrame = lookAtCF}):Play()
    task.wait(2.1)

    -- Теперь летим вперед
    move(p3, 12, Enum.EasingStyle.Linear)

    print("5. Посадка")
    -- Опускаемся ровно вниз в ту точку, которую ты скинул
    local finalLand = CFrame.new(garagePos, garagePos + flatDir)
    move(garagePos, 3, Enum.EasingStyle.Quad)

    -- Конец
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Доставлено ровно и красиво!")
end)
