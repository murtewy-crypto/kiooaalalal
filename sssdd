task.spawn(function()
    local player = game.Players.LocalPlayer
    local char = player.Character
    local human = char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    
    if not (seat and seat:IsA("VehicleSeat")) then 
        print("ОШИБКА: Сядь в машину!")
        return 
    end

    local car = seat.Parent
    while car and not car:IsA("Model") do car = car.Parent end

    -- Твои координаты гаража
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. Снимаем все "якоря" (на всякий случай)
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then p.Anchored = false end
    end

    -- 2. Создаем физические двигатели
    local bv = Instance.new("BodyVelocity", seat)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0) -- Сначала стоим

    local bg = Instance.new("BodyGyro", seat)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.D = 500 -- Плавность поворота
    bg.CFrame = seat.CFrame -- Держим текущий поворот

    -- Функция для полета (двигаем физикой)
    local function flyTo(targetPos, speed)
        while (targetPos - seat.Position).Magnitude > 5 do
            -- Всегда смотрим строго горизонтально на цель
            local lookPos = Vector3.new(targetPos.X, seat.Position.Y, targetPos.Z)
            bg.CFrame = CFrame.lookAt(seat.Position, lookPos)
            
            -- Толкаем машину вперед
            bv.Velocity = (targetPos - seat.Position).Unit * speed
            task.wait()
        end
        bv.Velocity = Vector3.new(0, 0, 0)
    end

    -- === ТВОЙ МАРШРУТ (ФИЗИЧЕСКИЙ) ===

    print("1. Едем 100 метров прямо...")
    local forwardPos = (seat.CFrame * CFrame.new(0, 0, -100)).Position
    flyTo(forwardPos, 40) -- Скорость 40

    print("2. Взлет на 70 метров...")
    local upPos = seat.Position + Vector3.new(0, flyHeight, 0)
    -- Поднимаемся вертикально, сохраняя направление
    bv.Velocity = Vector3.new(0, 25, 0)
    task.wait(flyHeight / 25)
    bv.Velocity = Vector3.new(0, 0, 0)

    print("3. Поворот НАЛЕВО...")
    bg.CFrame = bg.CFrame * CFrame.Angles(0, math.rad(90), 0)
    task.wait(2)

    print("4. Перелет к Гаражу...")
    -- Сначала летим в точку НАД гаражом
    local overGarage = Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z)
    flyTo(overGarage, 60) -- Летим быстро

    print("5. Мягкая посадка...")
    flyTo(garagePos, 20) -- Медленно вниз

    -- Удаляем силы, машина снова обычная
    task.wait(0.5)
    bv:Destroy()
    bg:Destroy()
    print("Прибыли в гараж!")
end)
