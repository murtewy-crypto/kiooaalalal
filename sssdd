task.spawn(function()
    local player = game.Players.LocalPlayer
    local RunService = game:GetService("RunService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    if not seat then print("Сядь в машину!") return end

    local car = seat.Parent
    while car and not car:IsA("Model") do car = car.Parent end

    -- === НАСТРОЙКИ (ТВОИ КООРДИНАТЫ) ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. СТАБИЛИЗАЦИЯ: Отключаем гравитацию и фиксируем наклон
    local bv = Instance.new("BodyVelocity", seat)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)

    local bg = Instance.new("BodyGyro", seat)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.D = 100 -- Быстрая реакция на поворот
    bg.CFrame = seat.CFrame

    -- Функция для ПРЯМОГО перемещения без задержек колес
    local function smoothMove(targetPos, duration)
        local startPos = seat.Position
        local startTime = tick()
        
        -- Поворачиваем нос строго горизонтально
        local lookPos = Vector3.new(targetPos.X, seat.Position.Y, targetPos.Z)
        if (lookPos - seat.Position).Magnitude > 0.5 then
            bg.CFrame = CFrame.lookAt(seat.Position, lookPos)
        end

        -- Цикл перемещения (каждый кадр физики)
        while tick() - startTime < duration do
            local alpha = (tick() - startTime) / duration
            -- Линейная интерполяция пути
            seat.CFrame = CFrame.new(startPos:Lerp(targetPos, alpha)) * (bg.CFrame - bg.CFrame.Position)
            RunService.Stepped:Wait()
        end
        seat.CFrame = CFrame.new(targetPos) * (bg.CFrame - bg.CFrame.Position)
    end

    -- === МАРШРУТ (БЕЗ ЗАДЕРЖЕК КОЛЕС) ===

    print("1. Едем 100м прямо")
    smoothMove((seat.CFrame * CFrame.new(0, 0, -100)).Position, 4)

    print("2. Взлет на 70м")
    smoothMove(seat.Position + Vector3.new(0, flyHeight, 0), 3)

    print("3. Поворот НАЛЕВО")
    local leftCF = bg.CFrame * CFrame.Angles(0, math.rad(90), 0)
    bg.CFrame = leftCF
    task.wait(1.5)

    print("4. Наведение на Гараж")
    local garageAtHeight = Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z)
    bg.CFrame = CFrame.lookAt(seat.Position, garageAtHeight)
    task.wait(1.5)

    print("5. Перелет к Гаражу")
    smoothMove(garageAtHeight, 10) -- Скорость перелета

    print("6. Посадка")
    smoothMove(garagePos, 3)

    -- ФИНАЛ: Удаляем силы плавно
    task.wait(0.5)
    bv:Destroy()
    bg:Destroy()
    print("Доставлено ровно! Колеса на месте.")
end)
