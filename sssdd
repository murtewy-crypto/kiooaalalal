task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    if not seat then print("Сядь в машину!") return end

    local car = seat.Parent
    while car and not car:IsA("Model") do car = car.Parent end

    -- === НАСТРОЙКИ ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. ПОДГОТОВКА: Привариваем колеса БЕЗ Anchored
    local tempWelds = {}
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            -- Если это колесо, привариваем его к сиденью
            if p.Name:lower():find("wheel") or p.Name:lower():find("tire") then
                local weld = Instance.new("WeldConstraint")
                weld.Part0 = p
                weld.Part1 = seat
                weld.Parent = p
                table.insert(tempWelds, weld)
            end
        end
    end

    -- 2. Стабилизация физики (чтобы машина не падала, но и не была Anchored)
    local bv = Instance.new("BodyVelocity", seat)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.new(0, 0, 0)

    local bg = Instance.new("BodyGyro", seat)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.CFrame = seat.CFrame

    -- Функция перемещения (двигаем физический объект через CFrame)
    local function move(targetCF, duration, style)
        local tween = TweenService:Create(seat, TweenInfo.new(duration, style or Enum.EasingStyle.Linear), {CFrame = targetCF})
        
        -- Синхронизируем гироскоп с поворотом
        local connection = game:GetService("RunService").Heartbeat:Connect(function()
            bg.CFrame = seat.CFrame
        end)
        
        tween:Play()
        tween.Completed:Wait()
        connection:Disconnect()
    end

    -- === МАРШРУТ (БЕЗ ANCHORED) ===

    print("1. Едем прямо (колеса на месте)")
    move(seat.CFrame * CFrame.new(0, 0, -100), 4, Enum.EasingStyle.Quad)

    print("2. Взлет вверх на 70м")
    local upPos = seat.Position + Vector3.new(0, flyHeight, 0)
    move(CFrame.new(upPos) * (seat.CFrame - seat.Position), 3, Enum.EasingStyle.Quad)

    print("3. Поворот НАЛЕВО")
    move(seat.CFrame * CFrame.Angles(0, math.rad(90), 0), 2)

    print("4. Наведение на Гараж")
    local lookCF = CFrame.lookAt(seat.Position, Vector3.new(garagePos.X, seat.Position.Y, garagePos.Z))
    move(lookCF, 2)

    print("5. Перелет")
    local flyTo = CFrame.new(garagePos + Vector3.new(0, flyHeight, 0), garagePos)
    move(flyTo, 12)

    print("6. Посадка")
    move(CFrame.new(garagePos) * (lookCF - lookCF.Position), 3, Enum.EasingStyle.Quad)

    -- ФИНАЛ: Удаляем сварку и силы
    print("Прибыли! Убираем фиксацию...")
    task.wait(0.5)
    for _, w in pairs(tempWelds) do w:Destroy() end
    bv:Destroy()
    bg:Destroy()
    
    print("Все готово. Машина цела!")
end)
