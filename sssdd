task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local char = player.Character
    if not char then return end

    -- Определяем, что именно мы двигаем (машину или игрока)
    local human = char:FindFirstChildOfClass("Humanoid")
    local target = (human and human.SeatPart) or char:FindFirstChild("HumanoidRootPart")
    
    if not target then return end

    -- Координаты Гаража (База бандитов)
    local garagePos = Vector3.new(-920, 70, -1500) 
    local flyHeight = 70

    -- Удаляем невидимые стены в небе
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and (v.Name == "InvisPart" or v.Name == "KillPart") then v:Destroy() end
    end

    -- Настройка физических сил
    local att0 = Instance.new("Attachment", target)
    local att1 = Instance.new("Attachment", workspace.Terrain)
    
    -- ИСПРАВЛЕНО: Для детали (Seat) используем .CFrame
    att1.CFrame = target.CFrame 

    local ap = Instance.new("AlignPosition", target)
    ap.Attachment0 = att0; ap.Attachment1 = att1
    ap.MaxForce = math.huge; ap.Responsiveness = 200

    local ao = Instance.new("AlignOrientation", target)
    ao.Attachment0 = att0; ao.Attachment1 = att1
    ao.MaxTorque = math.huge; ao.Responsiveness = 200; ao.RigidityEnabled = true

    -- Функция перемещения через TweenService
    local function move(targetCF, duration, style)
        local info = TweenInfo.new(duration, style or Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)
        local tween = TweenService:Create(att1, info, {CFrame = targetCF})
        tween:Play()
        tween.Completed:Wait()
    end

    -- === ТВОЙ МАРШРУТ ===

    print("Старт: 100 метров прямо")
    move(att1.CFrame * CFrame.new(0, 0, -100), 4, Enum.EasingStyle.Quad)

    print("Взлет: на 70 метров")
    move(att1.CFrame * CFrame.new(0, flyHeight, 0), 3, Enum.EasingStyle.Quad)

    print("Поворот: НАЛЕВО")
    -- math.rad(90) — это поворот на 90 градусов влево
    move(att1.CFrame * CFrame.Angles(0, math.rad(90), 0), 2)

    print("Перелет: Курс на Гараж")
    -- Направляем нос на гараж и летим
    local finalPos = CFrame.new(garagePos, garagePos + (garagePos - att1.Position).Unit)
    move(finalPos, 15)

    print("Посадка...")
    move(att1.CFrame * CFrame.new(0, -flyHeight, 0), 3)

    -- Удаляем временные силы
    ap:Destroy(); ao:Destroy(); att0:Destroy(); att1:Destroy()
    print("Миссия выполнена!")
end)
