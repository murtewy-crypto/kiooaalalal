task.spawn(function()
    local player = game.Players.LocalPlayer
    local TweenService = game:GetService("TweenService")
    local runService = game:GetService("RunService")
    local char = player.Character
    if not char then return end

    local human = char:FindFirstChildOfClass("Humanoid")
    local seat = human and human.SeatPart
    if not seat then print("Сядь в машину!") return end

    local car = seat.Parent
    while car and not car:IsA("Model") do car = car.Parent end

    -- === НАСТРОЙКИ (ТВОИ КООРДИНАТЫ) ===
    local garagePos = Vector3.new(-887.32, 93.82, 2154.55) 
    local flyHeight = 70 

    -- 1. ПОДГОТОВКА
    local wheels = {}
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then
            p.Anchored = true -- ЗАМОРАЖИВАЕМ, чтобы детали не разлетались
            p.CanCollide = false
            if p.Name:lower():find("wheel") or p.Name:lower():find("tire") then
                table.insert(wheels, p)
            end
        end
    end

    -- Функция для ИДЕАЛЬНО синхронного перемещения
    local function moveTo(targetPos, duration, lockLook)
        local startPos = car:GetPivot().Position
        local startCF = car:GetPivot()
        local elapsed = 0
        
        while elapsed < duration do
            local alpha = elapsed / duration
            local currentPos = startPos:Lerp(targetPos, alpha)
            local currentCF
            
            if lockLook then
                -- Смотрим строго вперед на цель, но без наклонов вверх/вниз
                local lookAtPos = Vector3.new(targetPos.X, currentPos.Y, targetPos.Z)
                if (lookAtPos - currentPos).Magnitude > 0.1 then
                    currentCF = CFrame.lookAt(currentPos, lookAtPos)
                else
                    currentCF = CFrame.new(currentPos) * (startCF - startPos)
                end
            else
                currentCF = CFrame.new(currentPos) * (startCF - startPos)
            end
            
            car:PivotTo(currentCF)
            
            -- Визуально крутим колеса, чтобы они "жили"
            for _, w in pairs(wheels) do
                w.CFrame = w.CFrame * CFrame.Angles(0.3, 0, 0)
            end
            
            elapsed = elapsed + task.wait()
        end
        car:PivotTo(CFrame.new(targetPos) * (car:GetPivot() - car:GetPivot().Position))
    end

    -- === МАРШРУТ (БЕЗ ОТСТАВАНИЯ КОЛЕС И КРИВИЗНЫ) ===

    print("1. Разгон 100м прямо")
    local p1 = (car:GetPivot() * CFrame.new(0, 0, -100)).Position
    moveTo(p1, 4, false)

    print("2. Взлет на 70м")
    local p2 = p1 + Vector3.new(0, flyHeight, 0)
    moveTo(p2, 3, false)

    print("3. Поворот НАЛЕВО")
    local leftCF = car:GetPivot() * CFrame.Angles(0, math.rad(90), 0)
    local val = Instance.new("CFrameValue")
    val.Value = car:GetPivot()
    val.Changed:Connect(function() car:PivotTo(val.Value) end)
    TweenService:Create(val, TweenInfo.new(2), {Value = leftCF}):Play()
    task.wait(2.1)
    val:Destroy()

    print("4. Перелет к Гаражу (Носом вперед)")
    -- Летим в точку НАД гаражом
    local p3 = Vector3.new(garagePos.X, p2.Y, garagePos.Z)
    moveTo(p3, 12, true)

    print("5. Посадка")
    moveTo(garagePos, 3, true)

    -- ФИНАЛ: Размораживаем
    task.wait(0.5)
    for _, p in pairs(car:GetDescendants()) do
        if p:IsA("BasePart") then p.Anchored = false p.CanCollide = true end
    end
    print("Прибыли! Все детали на месте.")
end)
